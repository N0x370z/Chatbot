# Copia a .env y rellena los valores.
# cp .env.example .env

TELEGRAM_BOT_TOKEN=tu_token_aqui
ADMIN_USER_ID=0
MAX_FILE_SIZE_MB=50
DOWNLOAD_PATH=./downloads
INCOMING_FILES_PATH=/data/incoming
PROCESSED_FILES_PATH=/data/processed
MAX_UPLOAD_SIZE_MB=50
# Calibre (opcional). Si está vacío, no se agrega a la biblioteca automáticamente.
CALIBRE_LIBRARY_PATH=
WORKER_POLL_INTERVAL_SEC=1.0
LOG_LEVEL=INFO
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=3

# API de libros (opcional). Si BOOKS_API_BASE_URL está vacío, /libro indica cómo configurarla.
# Ver contrato en bot/services/books_api.py
BOOKS_API_BASE_URL=
BOOKS_API_KEY=
BOOKS_API_SEARCH_PATH=books/search
BOOKS_API_DOWNLOAD_PATH=books/{id}/download
BOOKS_API_QUERY_PARAM=q
BOOKS_API_TIMEOUT_SEC=60
BOOKS_API_MAX_RESULTS=8

# Open Library se usa automáticamente si BOOKS_API_BASE_URL está vacío.
# No requiere configuración adicional.
